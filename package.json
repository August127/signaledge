{
  "name": "signaledge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c green,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "node --watch server/index.js",
    "build": "vite build",
    "benchmark": "node scripts/benchmark.mjs",
    "evaluate:scanner": "node scripts/evaluate-scanner.mjs",
    "evaluate:experiments": "node scripts/evaluate-scanner-experiments.mjs",
    "test": "node --test",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "5.0.4",
    "concurrently": "^10.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "lightweight-charts": "^5.2.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2",
    "zod": "^4.4.3"
  }
}
